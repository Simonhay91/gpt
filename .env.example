# Copy this file to .env and fill in the values
# cp .env.example .env

# ── AI APIs ───────────────────────────────────────────────
CLAUDE_API_KEY=
VOYAGE_API_KEY=
OPENAI_API_KEY=
EMERGENT_LLM_KEY=
BRAVE_API_KEY=

# ── PlanetWorkspace Catalog ───────────────────────────────
PLANET_PARTNER_KEY=
PLANET_API_URL=https://planetworkspace.com/api

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret

# ── Frontend URL (for docker build) ──────────────────────
REACT_APP_BACKEND_URL=http://localhost:8001

# ── Database ──────────────────────────────────────────────
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=Cluster0
DB_NAME=gpt

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
